# Railway 环境变量配置
# 部署时需要在 Railway Dashboard 中设置这些变量

# 只读模式（演示环境设置为 true，禁止修改密码）
READONLY_MODE=true

# 数据库路径（配置持久化卷requiredMountPath）
DATABASE_PATH=/toolsplus/data/notes.db

# CORS 允许的前端地址（GitHub Pages）
CORS_ORIGINS=https://upchr.github.io,http://localhost:5173

# JWT 密钥（建议用随机字符串）
JWT_SECRET=your-jwt-secret-key-change-this

# Redis（如果需要，Railway 可以添加 Redis 插件）
# REDIS_URL=redis://...
